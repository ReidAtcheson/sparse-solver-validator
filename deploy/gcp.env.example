# Copy this file to deploy/gcp.env and fill in the target-project values.
# deploy/gcp.env is ignored by Git. Keep private key material out of this file.

export PROJECT_ID="your-project-id"
export REGION="us-east1"
export SERVICE="sparse-validator-server"

export BUILD_SA_NAME="sparse-validator-builder"
export BUILD_SA_EMAIL="${BUILD_SA_NAME}@${PROJECT_ID}.iam.gserviceaccount.com"
export BUILD_SA_RESOURCE="projects/${PROJECT_ID}/serviceAccounts/${BUILD_SA_EMAIL}"

export RUNTIME_SA_NAME="sparse-validator-runtime"
export RUNTIME_SA_EMAIL="${RUNTIME_SA_NAME}@${PROJECT_ID}.iam.gserviceaccount.com"

export SIGNING_SECRET="sparse-validator-ed25519"
export SIGNING_SECRET_VERSION="1"
export SIGNING_KEY_FILE="/tmp/sparse-validator.key"
export PUBLIC_KEY_FILE="/tmp/sparse-validator.pub"
export ISSUER="your-validator-issuer"
export KEY_ID="ed25519-2026-01"

# This is documentation for the operator; choose the corresponding flags in
# the runbook. Valid values are "private" and "public".
export DEPLOYMENT_ACCESS="private"

export CPU="1"
export MEMORY="512Mi"
export CONCURRENCY="1"
export MAX_INSTANCES="1"
export CHALLENGE_LIFETIME_SECONDS="3600"
export REQUEST_TIMEOUT_SECONDS="120"
